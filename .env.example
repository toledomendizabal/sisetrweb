
# Variables de Entorno para SISETRWEB Bot

# --- Configuración de Telegram ---
TELEGRAM_BOT_TOKEN="TU_BOT_TOKEN_DE_TELEGRAM"
TELEGRAM_CHAT_ID="TU_CHAT_ID_DE_TELEGRAM"

# --- Configuración de Gmail (OAuth2) ---
# Ruta al archivo client_secret.json descargado de Google Cloud Console
GMAIL_CLIENT_SECRET_PATH="client_secret.json"
# Correo electrónico del remitente (debe coincidir con la cuenta de Google configurada)
GMAIL_SENDER_EMAIL="tu_correo@gmail.com"
# Correo electrónico del destinatario para los reportes diarios
GMAIL_RECIPIENT_EMAIL="tu_correo@gmail.com"

# --- Configuración de Twelve Data (API de respaldo) ---
TWELVEDATA_API_KEY="TU_API_KEY_DE_TWELVEDATA"

# Puedes obtener una API Key gratuita en https://twelvedata.com/
